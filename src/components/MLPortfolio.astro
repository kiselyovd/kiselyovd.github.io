---
import PortfolioRow from './PortfolioRow.astro';

const rows = [
  {
    repo: 'chest-xray-classifier',
    task: '3-class pneumonia',
    model: 'ConvNeXt-V2-Tiny',
    metrics: 'AUROC 97.5%',
    hfSlug: 'chest-xray-classifier',
  },
  {
    repo: 'brain-mri-segmentation',
    task: 'Tumor segmentation',
    model: 'SegFormer-B2',
    metrics: 'Dice 65.5%',
    hfSlug: 'brain-mri-segmentation',
  },
  {
    repo: 'vehicle-keypoints',
    task: '14-kp car pose',
    model: 'YOLO26-pose',
    metrics: 'OKS-mAP 50.4%',
    hfSlug: 'vehicle-keypoints',
    downloads: true,
  },
  {
    repo: 'cardio-risk-rf',
    task: 'Tabular CV-risk',
    model: 'LightGBM',
    metrics: 'ROC-AUC 79.8%',
    hfSlug: 'cardio-risk-rf',
  },
  {
    repo: 'grnti-text-classifier',
    task: 'GRNTI 28-class',
    model: 'XLM-RoBERTa',
    metrics: 'Top-1 72.4%',
    hfSlug: 'grnti-text-classifier',
  },
];
---

<section id="portfolio" class="fade-in px-6 md:px-10 py-16 md:py-20 border-b border-[color:var(--border)]">
  <span class="section-label block mb-3" data-i18n="port.label">/ Open-source ML portfolio</span>
  <h2
    class="text-[22px] md:text-[28px] font-bold tracking-[-0.02em] leading-[1.1] text-[color:var(--text)] mb-3 max-w-3xl"
    data-i18n="port.heading"
  >
    Five production-grade ML repos on a shared template
  </h2>
  <p class="text-[12px] md:text-[13px] text-[color:var(--text-muted)] leading-[1.55] mb-6 max-w-3xl" data-i18n="port.intro"></p>

  <table class="hidden md:table w-full border-collapse">
    <thead>
      <tr class="border-b border-[color:var(--border)]">
        <th class="text-left py-2 pr-4 font-mono text-[9px] tracking-[0.12em] uppercase text-[color:var(--text-subtle)] font-medium" data-i18n="port.col.repo">Repo</th>
        <th class="text-left py-2 pr-4 font-mono text-[9px] tracking-[0.12em] uppercase text-[color:var(--text-subtle)] font-medium" data-i18n="port.col.task">Task</th>
        <th class="text-left py-2 pr-4 font-mono text-[9px] tracking-[0.12em] uppercase text-[color:var(--text-subtle)] font-medium" data-i18n="port.col.model">Model</th>
        <th class="text-left py-2 font-mono text-[9px] tracking-[0.12em] uppercase text-[color:var(--text-subtle)] font-medium" data-i18n="port.col.metrics">Metrics</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((r) => <PortfolioRow {...r} variant="desktop" />)}
    </tbody>
  </table>

  <div class="md:hidden space-y-2">
    {rows.map((r) => <PortfolioRow {...r} variant="mobile" />)}
  </div>

  <div class="mt-10 rounded-lg border border-[color:var(--border)] bg-[color:var(--surface)] p-4 md:p-6">
    <span class="section-label block mb-2" data-i18n="port.research.label">/ Research track</span>
    <h3 class="text-[16px] md:text-[20px] font-bold tracking-[-0.01em] text-[color:var(--text)] mb-4" data-i18n="port.research.heading">
      Synthetic data &amp; monocular 3D pose
    </h3>

    <div class="max-w-3xl mx-auto mb-5">
      <figure class="research-stage relative rounded-md overflow-hidden border border-[color:var(--border)] mb-2.5">
        <video
          src="/portfolio/synth-demo.mp4"
          poster="/portfolio/synth-hero.jpg"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full block aspect-video object-cover"
        >
        </video>
        <figcaption
          class="absolute bottom-0 left-0 right-0 px-3 py-2 font-mono text-[9px] md:text-[10px] tracking-[0.08em] uppercase text-[color:var(--text)] bg-gradient-to-t from-black/75 to-transparent"
          data-i18n="port.research.cap.video"
        >
          Rendered in Epic UE5 City Sample - clean -&gt; 24-pt skeleton -&gt; wireframe
        </figcaption>
      </figure>

      <div class="grid grid-cols-3 gap-2 md:gap-2.5">
        <figure class="research-thumb rounded-md overflow-hidden border border-[color:var(--border)]">
          <img src="/portfolio/calibration.jpg" alt="Predicted bounding box and keypoints on a synthetic vehicle" loading="lazy" class="w-full aspect-[16/10] object-cover" />
          <figcaption class="px-2 py-1.5 font-mono text-[8px] md:text-[9px] tracking-[0.06em] uppercase text-[color:var(--text-subtle)]" data-i18n="port.research.cap.detect">Keypoints + bbox</figcaption>
        </figure>
        <figure class="research-thumb rounded-md overflow-hidden border border-[color:var(--border)]">
          <img src="/portfolio/zonegraph.jpg" alt="Top-down road-lane sampling across the City Sample map" loading="lazy" class="w-full aspect-[16/10] object-cover" />
          <figcaption class="px-2 py-1.5 font-mono text-[8px] md:text-[9px] tracking-[0.06em] uppercase text-[color:var(--text-subtle)]" data-i18n="port.research.cap.lanes">Road sampling</figcaption>
        </figure>
        <figure class="research-thumb rounded-md overflow-hidden border border-[color:var(--border)]">
          <img src="/portfolio/synth-labels.jpg" alt="Pixel-exact synthetic keypoint labels" loading="lazy" class="w-full aspect-[16/10] object-cover" />
          <figcaption class="px-2 py-1.5 font-mono text-[8px] md:text-[9px] tracking-[0.06em] uppercase text-[color:var(--text-subtle)]" data-i18n="port.research.cap.labels">Synthetic labels</figcaption>
        </figure>
      </div>
    </div>

    <ul class="space-y-2 text-[12px] text-[color:var(--text-muted)] leading-[1.55] list-disc pl-4">
      <li>
        <a
          href="https://github.com/kiselyovd/ue5-vehicle-synth"
          target="_blank"
          rel="noopener"
          class="font-mono text-[color:var(--accent)] hover:underline"
        >
          ue5-vehicle-synth
        </a>
        <span data-i18n="port.research.synth"></span>
        <a
          href="https://huggingface.co/datasets/kiselyovd/citysample-vehicle-keypoints-24pt"
          target="_blank"
          rel="noopener"
          class="text-[color:var(--accent)] hover:underline"
          data-i18n="port.research.dataset"
        >
          HF dataset
        </a>
      </li>
      <li>
        <a
          href="https://huggingface.co/kiselyovd/citysample-vehicle-keypoints-24pt"
          target="_blank"
          rel="noopener"
          class="font-mono text-[color:var(--accent)] hover:underline"
        >
          citysample-vehicle-keypoints-24pt
        </a>
        <span data-i18n="port.research.model"></span>
      </li>
      <li data-i18n="port.research.pose3d"></li>
    </ul>
  </div>
</section>
