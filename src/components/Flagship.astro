---
const tech = ['Rust', 'Tauri v2', 'React 19', 'mistral.rs', 'on-device LLM', 'multimodal AI'];
---

<section id="flagship" class="fade-in px-6 md:px-10 py-16 md:py-20 border-b border-[color:var(--border)]">
  <span class="section-label block mb-3" data-i18n="flag.label">/ Flagship application</span>
  <h2
    class="text-[22px] md:text-[28px] font-bold tracking-[-0.02em] leading-[1.1] text-[color:var(--text)] mb-3 max-w-3xl"
    data-i18n="flag.heading"
  >
    Dungeon Master AI
  </h2>
  <p class="text-[12px] md:text-[13px] text-[color:var(--text-muted)] leading-[1.6] mb-6 max-w-3xl" data-i18n="flag.desc"></p>

  <div class="grid md:grid-cols-2 gap-3 md:gap-4 max-w-4xl mb-5">
    <figure class="research-thumb rounded-md overflow-hidden border border-[color:var(--border)]">
      <img
        src="/portfolio/dm-ai-combat.jpg"
        alt="Dungeon Master AI combat: initiative tracker, virtual tabletop, action bar and AI tool-calls"
        loading="lazy"
        class="w-full aspect-[16/10] object-cover"
      />
      <figcaption
        class="px-2.5 py-1.5 font-mono text-[9px] tracking-[0.06em] uppercase text-[color:var(--text-subtle)]"
        data-i18n="flag.cap.combat"
      >
        Combat engine + VTT
      </figcaption>
    </figure>
    <figure class="research-thumb rounded-md overflow-hidden border border-[color:var(--border)]">
      <img
        src="/portfolio/dm-ai-onboarding.jpg"
        alt="Dungeon Master AI guided hero creation with class presets and character art"
        loading="lazy"
        class="w-full aspect-[16/10] object-cover"
      />
      <figcaption
        class="px-2.5 py-1.5 font-mono text-[9px] tracking-[0.06em] uppercase text-[color:var(--text-subtle)]"
        data-i18n="flag.cap.onboarding"
      >
        Guided hero creation
      </figcaption>
    </figure>
  </div>

  <div class="flex flex-wrap gap-2 mb-6 font-mono text-[10px]">
    {
      tech.map((t) => (
        <span class="px-2.5 py-1 rounded-full border border-[color:var(--border)] text-[color:var(--text-muted)]">
          {t}
        </span>
      ))
    }
  </div>

  <div class="flex flex-wrap gap-2">
    <a
      href="https://github.com/kiselyovd/dungeon-master-ai"
      target="_blank"
      rel="noopener"
      class="inline-block px-4 py-2 rounded-full bg-[color:var(--accent)] text-[color:var(--accent-contrast)] text-[12px] font-semibold hover:opacity-90 transition-opacity"
      data-i18n="flag.cta"
    >
      View on GitHub
    </a>
    <a
      href="https://github.com/kiselyovd/dungeon-master-ai/releases"
      target="_blank"
      rel="noopener"
      class="inline-block px-4 py-2 rounded-full border border-[color:var(--border)] text-[12px] text-[color:var(--text-muted)] hover:text-[color:var(--text)] transition-colors"
      data-i18n="flag.cta.releases"
    >
      Releases
    </a>
  </div>
</section>
