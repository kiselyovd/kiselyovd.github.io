---

<button
  type="button"
  class="lang-toggle font-mono text-[10px] tracking-[0.15em] uppercase px-2 py-1 border border-[color:var(--border)] rounded text-[color:var(--text-muted)] hover:text-[color:var(--text)] transition-colors"
  aria-label="Switch language"
>
  <span class="lang-option lang-en">EN</span>
  <span class="text-[color:var(--text-subtle)]"> · </span>
  <span class="lang-option lang-ru">RU</span>
</button>

<script is:inline>
  (function () {
    function paintAll() {
      var current = document.documentElement.getAttribute('lang') || 'en';
      document.querySelectorAll('.lang-toggle .lang-en').forEach(function (el) {
        el.style.color = current === 'en' ? 'var(--accent)' : '';
      });
      document.querySelectorAll('.lang-toggle .lang-ru').forEach(function (el) {
        el.style.color = current === 'ru' ? 'var(--accent)' : '';
      });
    }

    document.querySelectorAll('.lang-toggle').forEach(function (btn) {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', function () {
        if (typeof window.__setLang !== 'function') return;
        var current = document.documentElement.getAttribute('lang') || 'en';
        window.__setLang(current === 'en' ? 'ru' : 'en');
      });
    });

    document.addEventListener('langchange', paintAll);
    paintAll();
  })();
</script>
