---
const metaKeys = ['focus', 'deploy', 'industries', 'languages', 'education'] as const;
---

<section id="about" class="fade-in px-6 md:px-10 py-16 md:py-20 border-b border-[color:var(--border)]">
  <span class="section-label block mb-3" data-i18n="about.label">/ About</span>
  <h2 class="text-[22px] md:text-[28px] font-bold tracking-[-0.02em] leading-[1.1] text-[color:var(--text)] mb-6 max-w-3xl" data-i18n="about.heading">
    Lead ML Engineer with product and presale background
  </h2>

  <div class="grid md:grid-cols-[2fr_1fr] gap-6 md:gap-10 items-start">
    <div class="space-y-3 text-[color:var(--text-muted)] text-[13px] md:text-[14px] leading-[1.55]">
      <p data-i18n="about.p1"></p>
      <p data-i18n="about.p2"></p>
    </div>

    <dl class="font-mono text-[11px]">
      {
        metaKeys.map((k) => (
          <div class="grid grid-cols-[90px_1fr] gap-2 py-2 border-b border-[color:var(--border)]">
            <dt
              class="text-[9px] uppercase tracking-[0.1em] text-[color:var(--text-subtle)] self-center"
              data-i18n={`about.meta.${k}.label`}
            />
            <dd class="text-[color:var(--text)]" data-i18n={`about.meta.${k}.value`} />
          </div>
        ))
      }
    </dl>
  </div>
</section>
