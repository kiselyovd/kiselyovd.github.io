---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-5xl px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-lg font-bold tracking-tight text-zinc-900 dark:text-white hover:text-accent-500 dark:hover:text-accent-400 transition-colors">
      dk<span class="text-accent-500">.</span>
    </a>

    <nav class="hidden sm:flex items-center gap-8 text-sm font-medium text-zinc-600 dark:text-zinc-400">
      <a href="#about" class="hover:text-zinc-900 dark:hover:text-white transition-colors" data-i18n="nav.about">About</a>
      <a href="#projects" class="hover:text-zinc-900 dark:hover:text-white transition-colors" data-i18n="nav.projects">Projects</a>
      <a href="#stack" class="hover:text-zinc-900 dark:hover:text-white transition-colors" data-i18n="nav.stack">Stack</a>
      <a href="#contact" class="hover:text-zinc-900 dark:hover:text-white transition-colors" data-i18n="nav.contact">Contact</a>
    </nav>

    <div class="flex items-center gap-1">
      <LanguageSwitcher />
      <ThemeToggle />
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('site-header');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header.classList.add('bg-white/80', 'dark:bg-surface-900/80', 'backdrop-blur-lg', 'border-b', 'border-zinc-200/50', 'dark:border-zinc-800/50');
    } else {
      header.classList.remove('bg-white/80', 'dark:bg-surface-900/80', 'backdrop-blur-lg', 'border-b', 'border-zinc-200/50', 'dark:border-zinc-800/50');
    }
  });
</script>
