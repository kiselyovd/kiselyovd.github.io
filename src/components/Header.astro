---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import MobileMenu from './MobileMenu.astro';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 px-6 md:px-10 py-5 flex items-center justify-between transition-[background,backdrop-filter,border-color] duration-200"
  style="border-bottom: 1px solid transparent;"
>
  <a href="#" class="font-mono text-[11px] tracking-[0.15em] text-[color:var(--accent)]">kiselyov.dev</a>

  <nav class="hidden md:flex gap-5 font-mono text-[10px] tracking-[0.15em] uppercase text-[color:var(--text-muted)]">
    <a href="#about" data-i18n="nav.about" class="hover:text-[color:var(--text)] transition-colors">About</a>
    <a href="#work" data-i18n="nav.work" class="hover:text-[color:var(--text)] transition-colors">Work</a>
    <a href="#presale" data-i18n="nav.presale" class="hover:text-[color:var(--text)] transition-colors">Presale</a>
    <a href="#portfolio" data-i18n="nav.portfolio" class="hover:text-[color:var(--text)] transition-colors">Portfolio</a>
  </nav>

  <div class="hidden md:flex items-center gap-2">
    <LanguageSwitcher />
    <ThemeToggle />
  </div>

  <MobileMenu />
</header>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    if (!header) return;

    function paint() {
      var scrolled = window.scrollY > 40;
      if (scrolled) {
        header.style.backgroundColor = 'color-mix(in oklab, var(--bg) 72%, transparent)';
        header.style.backdropFilter = 'blur(12px) saturate(140%)';
        header.style.webkitBackdropFilter = 'blur(12px) saturate(140%)';
        header.style.borderBottomColor = 'var(--border)';
      } else {
        header.style.backgroundColor = 'transparent';
        header.style.backdropFilter = '';
        header.style.webkitBackdropFilter = '';
        header.style.borderBottomColor = 'transparent';
      }
    }

    paint();
    window.addEventListener('scroll', paint, { passive: true });
  })();
</script>
