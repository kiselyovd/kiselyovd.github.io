---
---

<section id="hero" class="hero-atmosphere relative min-h-[520px] md:min-h-[480px] lg:min-h-[540px] overflow-hidden pb-12 md:pb-16">

  <div class="relative z-10 px-6 md:px-10 pt-32 md:pt-36 lg:pt-40 max-w-[820px]">
    <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-[color:var(--highlight-amber)]" data-i18n="hero.tag">
      Lead ML Engineer · Moscow / remote
    </div>

    <h1 class="mt-3 mb-2 text-[32px] md:text-[44px] lg:text-[52px] font-extrabold tracking-[-0.025em] leading-[1.02] text-[color:var(--text)]">
      <span data-i18n="hero.headline.prefix">LLM systems that</span>
      <span class="text-[color:var(--accent)]" data-i18n="hero.headline.accent">ship</span>
      <span data-i18n="hero.headline.suffix">to production.</span>
    </h1>

    <p class="font-mono text-[12px] md:text-[14px] text-[color:var(--text-muted)]" data-i18n="hero.role">
      on-prem · air-gapped · multimodal
    </p>

    <div class="mt-6 grid grid-cols-2 md:flex md:flex-wrap gap-2 font-mono">
      <div class="px-3 py-2 border border-[color:var(--border)] rounded bg-black/35 text-[10px] text-[color:var(--text-muted)]">
        <strong class="block text-[16px] text-[color:var(--accent)] mb-[2px]" data-i18n="hero.fact1.value">5.5y</strong>
        <span data-i18n="hero.fact1.label">in ML &amp; dev</span>
      </div>
      <div class="px-3 py-2 border border-[color:var(--border)] rounded bg-black/35 text-[10px] text-[color:var(--text-muted)]">
        <strong class="block text-[16px] text-[color:var(--accent)] mb-[2px]" data-i18n="hero.fact2.value">4</strong>
        <span data-i18n="hero.fact2.label">enterprise AI systems</span>
      </div>
      <div class="px-3 py-2 border border-[color:var(--border)] rounded bg-black/35 text-[10px] text-[color:var(--text-muted)]">
        <strong class="block text-[16px] text-[color:var(--accent)] mb-[2px]" data-i18n="hero.fact3.value">10+</strong>
        <span data-i18n="hero.fact3.label">presales led</span>
      </div>
      <div class="px-3 py-2 border border-[color:var(--border)] rounded bg-black/35 text-[10px] text-[color:var(--text-muted)]">
        <strong class="block text-[16px] text-[color:var(--accent)] mb-[2px]" data-i18n="hero.fact4.value">5</strong>
        <span data-i18n="hero.fact4.label">open-source ML repos</span>
      </div>
    </div>

    <div class="mt-6 flex gap-2">
      <a
        href="#work"
        class="px-4 py-2 rounded-full bg-[color:var(--accent)] text-[color:var(--accent-contrast)] text-[12px] font-semibold hover:opacity-90 transition-opacity"
        data-i18n="hero.cta.primary"
      >
        View work
      </a>
      <a
        href="https://github.com/kiselyovd"
        target="_blank"
        rel="noopener"
        class="px-4 py-2 rounded-full border border-[color:var(--border)] text-[12px] text-[color:var(--text-muted)] hover:text-[color:var(--text)] transition-colors"
        data-i18n="hero.cta.secondary"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
