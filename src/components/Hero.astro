<section class="min-h-screen flex items-center justify-center px-6 pt-20">
  <div class="max-w-3xl mx-auto text-center">
    <div class="fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-800/50 text-sm text-zinc-600 dark:text-zinc-400">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
