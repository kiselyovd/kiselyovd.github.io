---

<section id="contact" class="fade-in px-6 md:px-10 py-20 md:py-24 text-center">
  <span class="section-label block mb-3" data-i18n="contact.label">/ Contact</span>
  <h2 class="text-[28px] md:text-[32px] font-bold tracking-[-0.02em] text-[color:var(--text)] mb-2" data-i18n="contact.heading">
    Get in touch
  </h2>
  <p class="font-mono text-[11px] text-[color:var(--text-subtle)] mb-6" data-i18n="contact.sublabel">
    hiring · consulting · presale
  </p>

  <div class="flex gap-2 justify-center flex-wrap">
    <a
      href="https://github.com/kiselyovd"
      target="_blank"
      rel="noopener"
      class="px-4 py-2 rounded-full bg-[color:var(--accent)] text-[color:var(--accent-contrast)] text-[12px] font-semibold"
    >
      GitHub @kiselyovd
    </a>
    <a
      href="https://huggingface.co/kiselyovd"
      target="_blank"
      rel="noopener"
      class="px-4 py-2 rounded-full border border-[color:var(--border)] text-[12px] text-[color:var(--text-muted)] hover:text-[color:var(--text)] transition-colors"
    >
      🤗 HuggingFace
    </a>
  </div>
</section>
