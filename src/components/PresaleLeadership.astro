---
const columns = ['col1', 'col2', 'col3'] as const;
---

<section id="presale" class="fade-in px-6 md:px-10 py-16 md:py-20 border-b border-[color:var(--border)]">
  <span class="section-label block mb-3" data-i18n="pres.label">/ Presale &amp; leadership</span>
  <h2
    class="text-[22px] md:text-[28px] font-bold tracking-[-0.02em] leading-[1.1] text-[color:var(--text)] mb-6 max-w-3xl"
    data-i18n="pres.heading"
  >
    Presale architecture, tech lead, mentoring
  </h2>

  <div class="grid md:grid-cols-3 gap-3 md:gap-4">
    {
      columns.map((c) => (
        <div class="bg-[color:var(--surface)] border border-[color:var(--border)] rounded-md p-4 md:p-5">
          <h4
            class="font-mono text-[11px] tracking-[0.1em] uppercase text-[color:var(--accent)] mb-2"
            data-i18n={`pres.${c}.title`}
          />
          <div
            class="text-[22px] md:text-[24px] font-extrabold tracking-[-0.02em] text-[color:var(--text)] mb-1"
            data-i18n={`pres.${c}.big`}
          />
          <p
            class="text-[11px] md:text-[12px] text-[color:var(--text-muted)] leading-[1.45]"
            data-i18n={`pres.${c}.desc`}
          />
        </div>
      ))
    }
  </div>
</section>
