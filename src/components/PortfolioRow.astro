---
interface Props {
  repo: string;
  task: string;
  model: string;
  metrics: string;
  hfSlug: string;
  variant: 'desktop' | 'mobile';
  downloads?: boolean;
}
const { repo, task, model, metrics, hfSlug, variant, downloads = false } = Astro.props;
const githubUrl = `https://github.com/kiselyovd/${repo}`;
const hfUrl = `https://huggingface.co/kiselyovd/${hfSlug}`;
const docsUrl = `https://kiselyovd.github.io/${repo}/`;
// Live monthly-download badge (auto-refreshing) for the breakout model.
const dlBadge = `https://img.shields.io/badge/dynamic/json?url=https%3A%2F%2Fhuggingface.co%2Fapi%2Fmodels%2Fkiselyovd%2F${hfSlug}&query=%24.downloads&label=%F0%9F%A4%97%20downloads%2Fmo&color=ffd21e&cacheSeconds=86400`;
---

{
  variant === 'desktop' ? (
    <tr class="border-b border-[color:var(--border)]">
      <td class="py-3 pr-4">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener"
          class="font-mono text-[11px] font-semibold text-[color:var(--accent)] hover:underline"
        >
          {repo}
        </a>
      </td>
      <td class="py-3 pr-4 text-[12px] text-[color:var(--text-muted)]">{task}</td>
      <td class="py-3 pr-4 text-[12px] text-[color:var(--text-muted)]">{model}</td>
      <td class="py-3 font-mono text-[11px] text-[color:var(--text)]">
        {metrics}
        <a
          href={hfUrl}
          target="_blank"
          rel="noopener"
          class="ml-2 inline-block px-1.5 py-0.5 rounded text-[9px] bg-[color:var(--accent-soft)] text-[color:var(--accent-soft-text)]"
        >
          HF
        </a>
        <a
          href={docsUrl}
          target="_blank"
          rel="noopener"
          class="ml-2 inline-block px-1.5 py-0.5 rounded text-[9px] bg-[color:var(--accent-soft)] text-[color:var(--accent-soft-text)]"
        >
          Docs
        </a>
        {downloads && (
          <img src={dlBadge} alt="HuggingFace downloads per month" class="ml-2 inline-block align-middle h-[18px]" loading="lazy" />
        )}
      </td>
    </tr>
  ) : (
    <article class="bg-[color:var(--surface)] border border-[color:var(--border)] rounded-md p-3">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener"
        class="font-mono text-[12px] font-semibold text-[color:var(--accent)]"
      >
        {repo}
      </a>
      <div class="text-[10px] text-[color:var(--text-muted)] mt-1">{task} · {model}</div>
      <div class="font-mono text-[10px] text-[color:var(--text)] mt-1 flex items-center gap-2">
        {metrics}
        <a
          href={hfUrl}
          target="_blank"
          rel="noopener"
          class="px-1.5 py-0.5 rounded text-[9px] bg-[color:var(--accent-soft)] text-[color:var(--accent-soft-text)]"
        >
          HF
        </a>
        <a
          href={docsUrl}
          target="_blank"
          rel="noopener"
          class="px-1.5 py-0.5 rounded text-[9px] bg-[color:var(--accent-soft)] text-[color:var(--accent-soft-text)]"
        >
          Docs
        </a>
        {downloads && (
          <img src={dlBadge} alt="HuggingFace downloads per month" class="inline-block align-middle h-[16px]" loading="lazy" />
        )}
      </div>
    </article>
  )
}
