---
import '../styles/global.css';
import { translations } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Lead ML Engineer. LLM systems, RAG, and multimodal pipelines for enterprise - on-premise and air-gapped.',
} = Astro.props;

const i18nJson = JSON.stringify(translations);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://kiselyovd.github.io" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script is:inline>
      (function () {
        var saved = null;
        try {
          if (typeof localStorage !== 'undefined') saved = localStorage.getItem('theme');
        } catch (_) {}
        var mode = saved || 'system';
        var resolved = mode === 'system'
          ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
          : mode;
        document.documentElement.classList.toggle('light', resolved === 'light');
        document.documentElement.classList.toggle('dark', resolved === 'dark');
        document.documentElement.setAttribute('data-theme-mode', mode);
      })();
    </script>

    <script is:inline id="i18n-data" type="application/json" set:html={i18nJson}></script>

    <script is:inline>
      window.__setLang = function (lang) {
        var data = JSON.parse(document.getElementById('i18n-data').textContent);
        var dict = data[lang];
        if (!dict) return;
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('lang', lang);
        document.querySelectorAll('[data-i18n]').forEach(function (el) {
          var key = el.getAttribute('data-i18n');
          if (dict[key] !== undefined) el.textContent = dict[key];
        });
        try {
          localStorage.setItem('lang', lang);
        } catch (_) {}
        document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: lang } }));
      };
      (function () {
        function applyInitialLang() {
          var saved = null;
          try {
            saved = localStorage.getItem('lang');
          } catch (_) {}
          var lang = saved || (navigator.language && navigator.language.startsWith('ru') ? 'ru' : 'en');
          window.__setLang(lang);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyInitialLang);
        } else {
          applyInitialLang();
        }
      })();
    </script>

    <script is:inline>
      window.__setThemeMode = function (mode) {
        var resolved = mode === 'system'
          ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
          : mode;
        document.documentElement.classList.toggle('light', resolved === 'light');
        document.documentElement.classList.toggle('dark', resolved === 'dark');
        document.documentElement.setAttribute('data-theme-mode', mode);
        try {
          localStorage.setItem('theme', mode);
        } catch (_) {}
        document.dispatchEvent(new CustomEvent('thememodechange', { detail: { mode: mode, resolved: resolved } }));
      };

      var mq = window.matchMedia('(prefers-color-scheme: light)');
      mq.addEventListener('change', function () {
        var mode = document.documentElement.getAttribute('data-theme-mode') || 'system';
        if (mode === 'system') window.__setThemeMode('system');
      });
    </script>
  </head>
  <body class="min-h-screen">
    <slot />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) entry.target.classList.add('visible');
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
        );
        document.querySelectorAll('.fade-in').forEach(function (el) {
          observer.observe(el);
        });
      });
    </script>

    <script is:inline>
      (function () {
        var hero = document.getElementById('hero');
        if (!hero) return;

        var ticking = false;
        function update() {
          var rect = hero.getBoundingClientRect();
          if (rect.bottom < 0) {
            ticking = false;
            return;
          }
          var y = Math.max(0, -rect.top);
          var maxShift = 80;
          var shift = Math.min(y * 0.18, maxShift);
          hero.style.setProperty('--hero-parallax', '-' + shift.toFixed(1) + 'px');
          ticking = false;
        }
        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(update);
        }
        update();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
